         })}

         {/* Add another child */}
         <div style={{background:B.white,borderRadius:20,padding:20,boxShadow:"0 4px 20px rgba(0,0,0,0.07)",border:`1px solid ${B.border}`}}>
           <p style={{fontWeight:700,fontSize:14,color:B.text,marginBottom:12}}>Add another child</p>
           <div style={{display:"flex",gap:8,marginBottom:12}}>
             <input type="text" value={nameInput} onChange={e=>setNameInput(e.target.value)}
               onKeyDown={e=>e.key==="Enter"&&addToRoster()}
               placeholder="Child's name..." maxLength={20}
               style={{flex:1,padding:"9px 14px",borderRadius:12,border:`2px solid ${B.border}`,fontSize:14,fontFamily:"'DM Sans'",color:B.text,background:"#FAFAFA"}}/>
             <button className="abtn" onClick={addToRoster}
               style={{background:`linear-gradient(135deg,${B.teal},${B.tealDark})`,color:"#fff",border:"none",borderRadius:12,padding:"0 18px",fontSize:20,fontWeight:700,cursor:"pointer"}}>+</button>
           </div>
           <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
             {CHILD_COLORS.map((c,i)=>(
               <button key={i} onClick={()=>setPickColorIdx(i)} title={c.label}
                 style={{width:28,height:28,borderRadius:"50%",background:c.bg,border:pickColorIdx===i?`3px solid ${B.text}`:`3px solid transparent`,cursor:"pointer",transition:"transform 0.15s",transform:pickColorIdx===i?"scale(1.15)":"scale(1)"}}/>
             ))}
           </div>
         </div>
       </div>
     )}
   </div>
 )}

 </main>
 </div>
 );
}

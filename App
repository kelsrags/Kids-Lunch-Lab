 const exportToCalendar = (plans) => {
 const pad = n => String(n).padStart(2,'0');
 const now = new Date();
 // Find next Monday as the anchor week
 const anchor = new Date(now);
 const dow = anchor.getDay(); // 0=Sun
 const toMon = dow === 0 ? 1 : (8 - dow); // days until next Monday
 anchor.setDate(anchor.getDate() + (dow === 1 ? 0 : toMon));

 const dayOffset = {Monday:0,Tuesday:1,Wednesday:2,Thursday:3,Friday:4,Saturday:5,Sunday:6};

 const lines = [
 "BEGIN:VCALENDAR",
 "VERSION:2.0",
 "PRODID:-//Real Kids Health//Kids' Lunch Lab//EN",
 "CALSCALE:GREGORIAN",
 "METHOD:PUBLISH",
 "X-WR-CALNAME:Kids' Lunch Lab",
 "X-WR-TIMEZONE:America/Chicago",
 ];

 plans.forEach(cp => {
 cp.selectedDays.forEach(day => {
 const meal = cp.meals[day] || {};
 const offset = dayOffset[day] ?? 0;
 const d = new Date(anchor);
 d.setDate(d.getDate() + offset);
 const dateStr = `${d.getFullYear()}${pad(d.getMonth()+1)}${pad(d.getDate())}`;

 // Build meal description
 const descParts = [];
 STEPS.forEach(s => {
 const val = meal[s.key];
 const items = Array.isArray(val) ? val : (val ? [val] : []);
 const filtered = items.filter(i => i && i.name !== "None");
 if (filtered.length) descParts.push(`${s.label}: ${filtered.map(i=>i.name).join(" + ")}`);
 });

 const uid = `${dateStr}-${cp.child.name.replace(/\s/g,'')}-${Math.random().toString(36).slice(2)}@realkidshealth`;
 const summary = `${cp.child.name}'s Lunch — Kids' Lunch Lab`;
 const desc = descParts.join("\\n");
 const stamp = `${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}T${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}Z`;

 lines.push("BEGIN:VEVENT");
 lines.push(`UID:${uid}`);
 lines.push(`DTSTAMP:${stamp}`);
 lines.push(`DTSTART;VALUE=DATE:${dateStr}`);
 lines.push(`DTEND;VALUE=DATE:${dateStr}`);
 lines.push(`SUMMARY:${summary}`);
 lines.push(`DESCRIPTION:${desc}`);
 lines.push("CATEGORIES:Meal Plan");
 lines.push("END:VEVENT");
 });
 });

 lines.push("END:VCALENDAR");

 const blob = new Blob([lines.join("\r\n")], {type:"text/calendar;charset=utf-8"});
 const url = URL.createObjectURL(blob);
 const a = document.createElement("a");
 a.href = url; a.download = "kid-built-meals.ics";
 document.body.appendChild(a); a.click();
 document.body.removeChild(a);
 URL.revokeObjectURL(url);
 flash("📆 Calendar file downloaded!");
 };


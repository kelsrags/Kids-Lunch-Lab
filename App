// Meal plan only — clean, no grocery list
function buildMealShareText(childPlans) {
 const lines = ["🥗 Kids' Lunch Lab — Real Kids' Health", ""];
 childPlans.forEach(cp => {
 lines.push(`👤 ${cp.child.name}`);
 cp.selectedDays.forEach(day => {
 lines.push(`📅 ${day}`);
 const meal = cp.meals[day] || {};
 STEPS.forEach(s => {
 const val = meal[s.key];
 const items = Array.isArray(val) ? val : (val ? [val] : []);
 const filtered = items.filter(i => i && i.name !== "None");
 if (filtered.length === 0) return;
 lines.push(` ${s.label}: ${filtered.map(i => i.name).join(" + ")}`);
 });
 lines.push("");
 });
 });
 return lines.join("\n").trim();
}

// Grocery list only
function buildGroceryShareText(grocery) {
 const checked = Object.entries(grocery)
 .filter(([, v]) => v.checked)
 .map(([name]) => ` • ${name}`);
 if (!checked.length) return "🛒 Grocery list is empty!";
 return ["🛒 Grocery List — Kids' Lunch Lab", "", ...checked].join("\n");
}


// ── TTS ───────────────────────────────────────────────────────────────────
// Preferred voice keywords — tries each in order until one matches
const VOICE_PREFS = [
 "Samantha", // macOS/iOS — warm, natural American English
 "Google US English", // Chrome — clear and friendly
 "Karen", // macOS Australian — bright and pleasant
 "Moira", // macOS Irish — warm
 "Tessa", // macOS South African
 "Fiona", // macOS Scottish
 "Victoria", // macOS
 "Allison", // macOS
 "Ava", // macOS — newer neural voice
 "Joanna", // some Android
 "en-US", // any English (US) as fallback
 "en-GB", // any English (UK) as fallback
];

let _cachedVoice = null;

function getBestVoice() {
 if (_cachedVoice) return _cachedVoice;
 const voices = window.speechSynthesis.getVoices();
 if (!voices.length) return null;
 for (const pref of VOICE_PREFS) {
 const match = voices.find(v =>
 v.name.includes(pref) || v.lang.startsWith(pref)
 );
 if (match) { _cachedVoice = match; return match; }
 }
 // Last resort: any English voice
 const eng = voices.find(v => v.lang.startsWith("en"));
 if (eng) { _cachedVoice = eng; return eng; }
 return voices[0];
}

function speak(text) {
 if (!window.speechSynthesis) return;
 window.speechSynthesis.cancel();
 const u = new SpeechSynthesisUtterance(text);
 u.rate = 0.90; // slightly slower than default — friendly, clear
 u.pitch = 1.05; // just a touch warmer
 u.volume = 1.0;

 // Voices load async — try immediately, retry once voices populate
 const voice = getBestVoice();
 if (voice) {
 u.voice = voice;
 window.speechSynthesis.speak(u);
 } else {
 // Voices not loaded yet — wait for them then speak
 window.speechSynthesis.onvoiceschanged = () => {
 _cachedVoice = null; // reset cache so we re-pick
 const v = getBestVoice();
 if (v) u.voice = v;
 window.speechSynthesis.speak(u);
 window.speechSynthesis.onvoiceschanged = null;
 };
 // Also try without a specific voice in case onvoiceschanged never fires
 setTimeout(() => {
 if (!window.speechSynthesis.speaking) {
 window.speechSynthesis.speak(u);
 }
 }, 300);
 }
}

function SpeakBtn({ text, size = 14, light = false }) {
 return (
 <button
 onClick={(e) => { e.stopPropagation(); speak(text); }}
 title={`Hear "${text}"`}
 style={{
 background: light ? "rgba(255,255,255,0.25)" : "rgba(0,0,0,0.06)",
 border: "none", cursor: "pointer", padding: "3px 6px",
 borderRadius: 8, fontSize: size, lineHeight: 1,
 display: "inline-flex", alignItems: "center", flexShrink: 0,
 }}
 aria-label={`Read aloud: ${text}`}
 >🔊</button>
 );
}

